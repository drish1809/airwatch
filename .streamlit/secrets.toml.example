# ─────────────────────────────────────────────────────────────────
# EXAMPLE — copy this file to .streamlit/secrets.toml
# and fill in your real values.
#
# NEVER commit secrets.toml to GitHub.
# On Streamlit Cloud paste these values in Settings → Secrets.
# ─────────────────────────────────────────────────────────────────

[api]
openweather_api_key = "PASTE_YOUR_OPENWEATHER_KEY_HERE"

[database]
url = "postgresql://postgres:YOUR_PASSWORD@db.XXXX.supabase.co:5432/postgres"
